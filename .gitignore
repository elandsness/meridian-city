**/target/
**/dist/
**/build/
**/.gradle/
**/node_modules/
**/__pycache__/
**/*.pyc
**/*.pyo
**/venv/
**/.venv/
**/bin/
**/vendor/

# IDE
.idea/
.vscode/
*.iml
*.iws
*.ipr
.DS_Store

# Go
# go.sum is intentionally NOT ignored — it should be committed for reproducible builds.
