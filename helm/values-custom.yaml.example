# =============================================================================
# Meridian City Platform — Custom Secrets / Environment Overrides
# =============================================================================
# This file contains credentials and environment-specific settings.
# Everything else (Kafka version, resource limits, replica counts, etc.)
# lives in values.yaml — do NOT copy those defaults here, as any value
# present in this file silently overrides values.yaml.
#
# Setup:
#   cp helm/values-custom.yaml.example helm/values-custom.yaml
#   # Edit values-custom.yaml and fill in your credentials.
#   # values-custom.yaml is git-ignored (it contains secrets).
#
# Deploy:
#   ./scripts/deploy.sh install -f helm/values-custom.yaml
# =============================================================================

# ---------------------------------------------------------------------------
# Image registry (REQUIRED)
# ---------------------------------------------------------------------------
# All app images are pulled from: <appImageRegistry>/<service-name>:<tag>
# The default in values.yaml is a placeholder — set this to your actual registry.
# For the canonical elandsness/meridian-city repo:
appImageRegistry: "ghcr.io/elandsness/meridian-city"

# ---------------------------------------------------------------------------
# Dynatrace tenant (REQUIRED)
# ---------------------------------------------------------------------------
dynatrace:
  # REQUIRED: Dynatrace SaaS tenant API URL
  # Format: https://<environment-id>.live.dynatrace.com/api
  apiUrl: ""

  # REQUIRED: Dynatrace API token
  # Required scopes: metrics.ingest, logs.ingest, openTelemetryTrace.ingest,
  #                  entities.read, settings.write, DataExport
  apiToken: ""

  # REQUIRED: OTLP ingest endpoint for OpenTelemetry data
  # Format: https://<environment-id>.live.dynatrace.com/api/v2/otlp
  otlpEndpoint: ""

  # Dynatrace environment ID (the subdomain part of your tenant URL)
  # e.g., abc12345 from https://abc12345.live.dynatrace.com
  environmentId: ""

  # Deployment environment label (visible in Dynatrace entity properties)
  deploymentEnvironment: "demo"

  # Kubernetes cluster name (visible in Dynatrace k8s monitoring)
  clusterName: "meridian-cluster"

  # Whether to deploy the Dynatrace Operator for OneAgent auto-instrumentation.
  # When enabled, the operator and a DynaKube CR are created in the 'dynatrace' namespace.
  operator:
    enabled: true

# ---------------------------------------------------------------------------
# LLM / AI configuration (for the citizen chatbot and ai-service)
# ---------------------------------------------------------------------------
llm:
  # Provider selection: openai | anthropic | local
  provider: "openai"

  openai:
    # REQUIRED if provider=openai
    apiKey: ""
    model: "gpt-4o"
    baseUrl: "https://api.openai.com/v1"

  anthropic:
    # REQUIRED if provider=anthropic
    apiKey: ""
    model: "claude-sonnet-4-6"

  local:
    # Used when provider=local; assumes Ollama running in-cluster
    endpoint: "http://ollama:11434"
    model: "llama3"
