# =============================================================================
# Meridian City Platform — Custom Secrets / Environment Overrides
# =============================================================================
# This file contains credentials and environment-specific settings.
# Everything else (Kafka version, resource limits, replica counts, etc.)
# lives in values.yaml — do NOT copy those defaults here, as any value
# present in this file silently overrides values.yaml.
#
# Setup:
#   cp helm/values-custom.yaml.example helm/values-custom.yaml
#   # Edit values-custom.yaml and fill in your credentials.
#   # values-custom.yaml is git-ignored (it contains secrets).
#
# Deploy (generates a fresh per-instance hash → release & namespace meridian-<hash>):
#   ./scripts/deploy.sh install -f helm/values-custom.yaml
#
# Multi-tenancy: a second concurrent install is just another `deploy.sh install`
# (it gets a new hash); the cluster-singleton operators are installed once and
# reused. Pin a hash with INSTANCE_HASH=<hash>. See docs/dynatrace-config-guide.md.
# =============================================================================

# ---------------------------------------------------------------------------
# Image registry (REQUIRED)
# ---------------------------------------------------------------------------
# All app images are pulled from: <appImageRegistry>/<service-name>:<tag>
# The default in values.yaml is a placeholder — set this to your actual registry.
# For the canonical elandsness/meridian-city repo:
appImageRegistry: "ghcr.io/elandsness/meridian-city"

# ---------------------------------------------------------------------------
# Dynatrace tenant (REQUIRED)
# ---------------------------------------------------------------------------
dynatrace:
  # REQUIRED: Dynatrace SaaS tenant API URL
  # Format: https://<environment-id>.live.dynatrace.com/api
  apiUrl: ""

  # REQUIRED: Dynatrace API token
  # Required scopes: metrics.ingest, logs.ingest, openTelemetryTrace.ingest,
  #                  entities.read, settings.write, DataExport
  apiToken: ""

  # REQUIRED: OTLP ingest endpoint for OpenTelemetry data
  # Format: https://<environment-id>.live.dynatrace.com/api/v2/otlp
  otlpEndpoint: ""

  # Dynatrace environment ID (the subdomain part of your tenant URL)
  # e.g., abc12345 from https://abc12345.live.dynatrace.com
  environmentId: ""

  # Deployment environment BASE label (visible in Dynatrace entity properties).
  # The per-instance hash is appended automatically (e.g. "demo" -> "demo-a1b2"),
  # so every concurrent install is filterable by a unique deployment.environment.
  deploymentEnvironment: "demo"

  # Kubernetes cluster name (visible in Dynatrace k8s monitoring). Leave EMPTY to
  # derive per-instance as "<release>-cluster" (e.g. meridian-a1b2-cluster) so each
  # install is a distinct cluster entity on the shared tenant. Pin a value only to
  # deliberately share one cluster name across instances (not recommended).
  clusterName: ""

  # Whether to deploy the Dynatrace Operator for OneAgent auto-instrumentation.
  # When enabled, the operator and a DynaKube CR are created in the 'dynatrace' namespace.
  operator:
    enabled: true

# ---------------------------------------------------------------------------
# RUM (Real User Monitoring) — front-end user sessions for the two SPAs.
# The agentless RUM JS is injected at runtime via nginx sub_filter (no rebuild).
# The application id / agent URL is shipped to every browser and is NOT a secret.
#
# To enable: in Dynatrace create a web application for each SPA
#   (Web > <app> > Settings > Instrumentation > Manual insertion), copy the
#   single-line <script ...></script> tag, paste it below, and set enabled: true.
# ---------------------------------------------------------------------------
publicPortal:
  rum:
    enabled: false
    snippet: ""   # e.g. '<script src="https://js-cdn.dynatrace.com/jstag/.../ruxitagentjs_....js" ...></script>'
opsDashboard:
  rum:
    enabled: false
    snippet: ""

# ---------------------------------------------------------------------------
# LLM / AI configuration (for the citizen chatbot and ai-service)
# ---------------------------------------------------------------------------
llm:
  # Provider selection: openai | anthropic | local
  provider: "openai"

  openai:
    # REQUIRED if provider=openai
    apiKey: ""
    model: "gpt-4o"
    baseUrl: "https://api.openai.com/v1"

  anthropic:
    # REQUIRED if provider=anthropic
    apiKey: ""
    model: "claude-sonnet-4-6"

  local:
    # When provider=local, the chart auto-deploys an in-cluster Ollama and
    # scripts/deploy.sh pulls `model` into it after the rollout. `endpoint`
    # must point at that in-cluster Service (default: http://ollama:11434).
    # Ollama tuning (image/resources/persistence) lives in values.yaml.
    endpoint: "http://ollama:11434"
    model: "llama3"

# ---------------------------------------------------------------------------
# Docker Hub credentials (OPTIONAL)
# ---------------------------------------------------------------------------
# Only needed if your cluster pulls images from Docker Hub and hits the
# anonymous pull rate limit (e.g. GKE Autopilot, shared NAT egress). The app
# images come from appImageRegistry (GHCR) and the Postgres/Kafka operators use
# public ghcr.io / quay.io images, so most clusters can leave this blank.
#
# When both fields are set, the chart creates a `dockerhub-pull-secret`
# (kubernetes.io/dockerconfigjson); reference it from global.imagePullSecrets to
# actually use it for pulls.
#
# Use a Docker Hub ACCESS TOKEN (Account → Security → New Access Token), not
# your account password.
#
# NOTE: this is the CLUSTER-side credential. CI image builds authenticate
# separately via the DOCKERHUB_USERNAME / DOCKERHUB_TOKEN GitHub Actions repo
# secrets — see docs/setup-guide.md (Continuous Integration).
dockerhub:
  username: ""
  token: ""
